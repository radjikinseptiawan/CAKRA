generator client {
  provider                    = "prisma-client-py"
  previewFeatures             = ["prismaSchemaFolder"]
  enable_experimental_decimal = "true"
  recursive_type_depth        = "5"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ccvtv {
  cctv_id              String         @id @default(uuid())
  camera_name          String
  converted_url        String?
  source_url           String
  latitude             Decimal
  category             CategoryCamera
  longitude            Decimal
  location_description String
  created_at           DateTime
}

model Accounts {
  account_id String   @id @default(uuid())
  username   String   @unique
  password   String
  Profile    Profile?
}

model Profile {
  profile_id String   @id @default(uuid())
  account_id String   @unique
  fullname   String
  role       Role
  email      String
  account    Accounts @relation(fields: [account_id], references: [account_id])
}

enum Role {
  OWNER
  STAFF
  VISITOR
}

enum CategoryCamera {
  PUBLIC
  PRIVATE
}
